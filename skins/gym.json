{
  "id": "gym",
  "name": "Fitness Center",
  "version": "1.0.0",
  "description": "Vertical skin for gym and fitness center member engagement. Exposes membership, class booking, training, and retention tools with standard governance.",

  "tools": {
    "include": ["customer-engagement.*"],
    "exclude": ["customer-engagement.pipeline.*", "customer-engagement.treatment.*"],
    "aliases": {
      "book_appointment": "customer-engagement.appointment.book",
      "cancel_appointment": "customer-engagement.appointment.cancel",
      "reschedule_appointment": "customer-engagement.appointment.reschedule",
      "send_reminder": "customer-engagement.reminder.send",
      "start_cadence": "customer-engagement.cadence.start",
      "stop_cadence": "customer-engagement.cadence.stop",
      "qualify_lead": "customer-engagement.lead.qualify",
      "score_lead": "customer-engagement.lead.score",
      "update_stage": "customer-engagement.journey.update_stage",
      "score_ltv": "customer-engagement.contact.score_ltv",
      "handle_objection": "customer-engagement.conversation.handle_objection",
      "escalate": "customer-engagement.conversation.escalate"
    }
  },

  "governance": {
    "profile": "observe",
    "policyOverrides": [],
    "spendLimits": {
      "dailyUsd": 100,
      "weeklyUsd": 500,
      "monthlyUsd": 1500
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are a helpful fitness center assistant. Help staff manage member communications, class bookings, and training schedules. Be energetic and motivational.",
    "replyTemplates": {
      "appointment_booked": "Session confirmed for {{contactName}} on {{date}} at {{time}}.",
      "appointment_cancelled": "Session for {{contactName}} on {{date}} has been cancelled.",
      "reminder_sent": "Reminder sent to {{contactName}} for their session on {{date}}.",
      "cadence_started": "Follow-up sequence started for {{contactName}}.",
      "cadence_stopped": "Follow-up sequence stopped for {{contactName}}."
    },
    "terminology": {
      "campaign": "program",
      "lead": "prospective member",
      "deal": "membership",
      "contact": "member",
      "pipeline": "member journey",
      "stage": "journey stage",
      "activity": "interaction"
    }
  },

  "playbooks": [
    {
      "id": "new-member-onboarding",
      "name": "New Member Onboarding",
      "trigger": "new member signup",
      "steps": [
        { "actionType": "customer-engagement.lead.qualify" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.cadence.start",
          "parameterDefaults": { "cadenceType": "new-member-welcome" }
        }
      ]
    },
    {
      "id": "trial-followup",
      "name": "Trial Follow-up",
      "trigger": "trial visit followup",
      "steps": [
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "post-trial" }
        },
        { "actionType": "customer-engagement.lead.score" }
      ]
    }
  ],

  "requiredCartridges": ["customer-engagement"],

  "channels": {
    "primary": "telegram",
    "enabled": ["telegram", "whatsapp", "instagram"]
  },

  "config": {
    "bannedPhrases": ["guaranteed weight loss", "miracle results"],
    "bookingUrl": "https://calendly.com/your-gym"
  }
}
