{
  "id": "gym",
  "name": "Fitness Center",
  "version": "2.0.0",
  "description": "Vertical skin for gym and fitness center operations. Exposes digital ads management (lead gen mode), speed-to-lead tools, membership booking, and member communications with standard governance.",

  "tools": {
    "include": [
      "customer-engagement.*",
      "digital-ads.platform.*",
      "digital-ads.health.*",
      "digital-ads.snapshot.*",
      "digital-ads.funnel.*",
      "digital-ads.portfolio.*",
      "digital-ads.structure.*",
      "digital-ads.campaign.*",
      "digital-ads.adset.*",
      "digital-ads.ad.*",
      "digital-ads.targeting.*",
      "digital-ads.creative.generate",
      "digital-ads.creative.generate_brief",
      "digital-ads.report.performance",
      "digital-ads.report.creative",
      "digital-ads.signal.*",
      "digital-ads.pacing.check",
      "digital-ads.alert.anomaly_scan",
      "digital-ads.alert.budget_forecast",
      "crm.*"
    ],
    "exclude": [
      "customer-engagement.pipeline.*",
      "customer-engagement.treatment.*",
      "digital-ads.campaign.setup_guided",
      "digital-ads.campaign.update_objective"
    ],
    "aliases": {
      "book_appointment": "customer-engagement.appointment.book",
      "cancel_appointment": "customer-engagement.appointment.cancel",
      "reschedule_appointment": "customer-engagement.appointment.reschedule",
      "send_reminder": "customer-engagement.reminder.send",
      "start_cadence": "customer-engagement.cadence.start",
      "stop_cadence": "customer-engagement.cadence.stop",
      "qualify_lead": "customer-engagement.lead.qualify",
      "score_lead": "customer-engagement.lead.score",
      "update_stage": "customer-engagement.journey.update_stage",
      "score_ltv": "customer-engagement.contact.score_ltv",
      "handle_objection": "customer-engagement.conversation.handle_objection",
      "escalate": "customer-engagement.conversation.escalate",
      "check_ads": "digital-ads.funnel.diagnose",
      "create_campaign": "digital-ads.campaign.create",
      "pause_campaign": "digital-ads.campaign.pause",
      "adjust_budget": "digital-ads.campaign.adjust_budget"
    }
  },

  "governance": {
    "profile": "observe",
    "policyOverrides": [
      {
        "name": "gym-campaign-create-approval",
        "description": "Campaign creation always requires owner approval",
        "rule": {
          "actionType": "digital-ads.campaign.create"
        },
        "effect": "require_approval"
      }
    ],
    "spendLimits": {
      "dailyUsd": 100,
      "weeklyUsd": 500,
      "monthlyUsd": 1500
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are an AI operator for a fitness center. You manage ad campaigns to attract new members and handle enquiries instantly. You also help staff manage member communications, class bookings, and training schedules. Be energetic and motivational.",
    "replyTemplates": {
      "appointment_booked": "Session confirmed for {{contactName}} on {{date}} at {{time}}.",
      "appointment_cancelled": "Session for {{contactName}} on {{date}} has been cancelled.",
      "reminder_sent": "Reminder sent to {{contactName}} for their session on {{date}}.",
      "cadence_started": "Follow-up sequence started for {{contactName}}.",
      "cadence_stopped": "Follow-up sequence stopped for {{contactName}}.",
      "campaign_created": "Campaign '{{campaignName}}' created with ${{dailyBudget}}/day budget.",
      "campaign_paused": "Campaign '{{campaignName}}' has been paused.",
      "budget_adjusted": "Budget for '{{campaignName}}' updated to ${{newBudget}}/day."
    },
    "terminology": {
      "campaign": "ad campaign",
      "lead": "prospective member",
      "deal": "membership",
      "contact": "member",
      "pipeline": "member journey",
      "stage": "journey stage",
      "activity": "interaction"
    },
    "welcomeMessage": "Welcome to {{businessName}}! I'm your AI operator. I manage your ad campaigns to attract new members and respond to enquiries instantly.\n\nI can also help with class bookings, reminders, and member communications.\n\nType 'help' to see everything I can do, or just tell me what you need!"
  },

  "funnelMode": "lead_gen",
  "leadChannel": "telegram",

  "playbooks": [
    {
      "id": "new-member-onboarding",
      "name": "New Member Onboarding",
      "trigger": "new member signup",
      "steps": [
        { "actionType": "customer-engagement.lead.qualify" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.cadence.start",
          "parameterDefaults": { "cadenceType": "new-member-welcome" }
        }
      ]
    },
    {
      "id": "trial-followup",
      "name": "Trial Follow-up",
      "trigger": "trial visit followup",
      "steps": [
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "post-trial" }
        },
        { "actionType": "customer-engagement.lead.score" }
      ]
    }
  ],

  "requiredCartridges": ["digital-ads", "customer-engagement", "crm"],

  "channels": {
    "primary": "telegram",
    "enabled": ["telegram", "whatsapp", "instagram"]
  },

  "stageDefinitions": {
    "interested": {
      "label": "Enquiry",
      "criteria": "Asked about membership or classes",
      "typicalDuration": "1-2 days"
    },
    "qualified": {
      "label": "Trial Booked",
      "criteria": "Trial class or tour scheduled",
      "typicalDuration": "2-5 days"
    },
    "quoted": {
      "label": "Membership Offered",
      "criteria": "Pricing and plans shared",
      "typicalDuration": "1-7 days"
    },
    "booked": { "label": "Trial Confirmed", "criteria": "Trial date locked in" },
    "showed": { "label": "Trial Completed", "criteria": "Attended trial class or tour" },
    "won": { "label": "Signed Up", "criteria": "Membership activated" },
    "lost": { "label": "Lost", "criteria": "Declined or no response" },
    "nurturing": { "label": "Re-Engagement", "criteria": "Follow-up sequence active" }
  },
  "dormancyThresholdDays": 30,
  "reopenWindowDays": 90,
  "fallbackSLA": {
    "urgent": { "dueDurationHours": 4 },
    "high": { "dueDurationHours": 12 },
    "medium": { "dueDurationHours": 24 },
    "low": { "dueDurationHours": 48 }
  },

  "config": {
    "bannedPhrases": ["guaranteed weight loss", "miracle results"],
    "bookingUrl": "https://calendly.com/your-gym"
  }
}
