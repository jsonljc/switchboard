{
  "id": "clinic",
  "name": "Dental Clinic",
  "version": "1.0.0",
  "description": "Vertical skin for dental clinic patient engagement. Exposes appointment, reminder, cadence, treatment, and review tools with guarded governance and WhatsApp as the primary channel.",

  "tools": {
    "include": ["customer-engagement.*"],
    "exclude": ["customer-engagement.pipeline.*"],
    "aliases": {
      "book_appointment": "customer-engagement.appointment.book",
      "cancel_appointment": "customer-engagement.appointment.cancel",
      "reschedule_appointment": "customer-engagement.appointment.reschedule",
      "send_reminder": "customer-engagement.reminder.send",
      "log_treatment": "customer-engagement.treatment.log",
      "request_review": "customer-engagement.review.request",
      "respond_to_review": "customer-engagement.review.respond",
      "start_cadence": "customer-engagement.cadence.start",
      "stop_cadence": "customer-engagement.cadence.stop",
      "qualify_lead": "customer-engagement.lead.qualify",
      "score_lead": "customer-engagement.lead.score",
      "update_stage": "customer-engagement.journey.update_stage",
      "score_ltv": "customer-engagement.contact.score_ltv",
      "handle_objection": "customer-engagement.conversation.handle_objection",
      "escalate": "customer-engagement.conversation.escalate"
    }
  },

  "governance": {
    "profile": "guarded",
    "policyOverrides": [
      {
        "name": "clinic-high-risk-cancellation",
        "description": "Require approval for appointment cancellations within 24 hours",
        "rule": {
          "actionType": "customer-engagement.appointment.cancel"
        },
        "effect": "require_approval"
      },
      {
        "name": "clinic-review-response-approval",
        "description": "Public review responses always require manager approval",
        "rule": {
          "actionType": "customer-engagement.review.respond"
        },
        "effect": "require_approval"
      }
    ],
    "spendLimits": {
      "dailyUsd": 200,
      "weeklyUsd": 1000,
      "monthlyUsd": 3000
    },
    "approvalRouting": {
      "channelPreference": "whatsapp"
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are a helpful dental clinic assistant. Help staff manage appointments, patient communications, and treatment records. Use clear, professional language appropriate for a healthcare setting.",
    "replyTemplates": {
      "appointment_booked": "Appointment confirmed for {{contactName}} on {{date}} at {{time}}.",
      "appointment_cancelled": "Appointment for {{contactName}} on {{date}} has been cancelled.",
      "reminder_sent": "Reminder sent to {{contactName}} for their appointment on {{date}}.",
      "treatment_logged": "Treatment record saved for {{contactName}}: {{treatmentType}}.",
      "review_requested": "Review request sent to {{contactName}}.",
      "cadence_started": "Outreach cadence started for {{contactName}}.",
      "cadence_stopped": "Outreach cadence stopped for {{contactName}}."
    },
    "terminology": {
      "campaign": "treatment plan",
      "lead": "prospective patient",
      "deal": "treatment case",
      "contact": "patient",
      "pipeline": "patient journey",
      "stage": "journey stage",
      "activity": "interaction"
    },
    "welcomeMessage": "Welcome to {{businessName}}! I'm your clinic assistant. I can help you book appointments, send reminders, and manage patient records.\n\nType 'help' to see everything I can do, or just tell me what you need!"
  },

  "playbooks": [
    {
      "id": "new-patient-intake",
      "name": "New Patient Intake",
      "trigger": "new patient intake",
      "steps": [
        { "actionType": "customer-engagement.lead.qualify" },
        { "actionType": "customer-engagement.lead.score" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.cadence.start",
          "parameterDefaults": { "cadenceType": "new-patient-welcome" }
        }
      ]
    },
    {
      "id": "post-treatment-followup",
      "name": "Post-Treatment Follow-up",
      "trigger": "post treatment follow up",
      "steps": [
        { "actionType": "customer-engagement.treatment.log" },
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "follow-up" }
        },
        { "actionType": "customer-engagement.review.request" }
      ]
    },
    {
      "id": "appointment-reschedule",
      "name": "Reschedule Appointment",
      "trigger": "reschedule appointment",
      "steps": [
        { "actionType": "customer-engagement.appointment.cancel" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "rescheduled" }
        }
      ]
    }
  ],

  "requiredCartridges": ["customer-engagement"],

  "channels": {
    "primary": "whatsapp",
    "enabled": ["whatsapp", "telegram", "instagram", "messenger"]
  },

  "config": {
    "bannedPhrases": ["competitor_name", "guaranteed results", "100% success"],
    "bookingUrl": "https://calendly.com/your-clinic"
  }
}
