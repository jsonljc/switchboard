{
  "id": "clinic",
  "name": "Dental Clinic",
  "version": "2.0.0",
  "description": "Vertical skin for dental clinic ad operations and patient engagement. Exposes digital ads management (lead gen mode), speed-to-lead tools, appointment booking, and patient communications with guarded governance.",

  "tools": {
    "include": [
      "customer-engagement.*",
      "digital-ads.platform.*",
      "digital-ads.health.*",
      "digital-ads.snapshot.*",
      "digital-ads.funnel.*",
      "digital-ads.portfolio.*",
      "digital-ads.structure.*",
      "digital-ads.campaign.*",
      "digital-ads.adset.*",
      "digital-ads.ad.*",
      "digital-ads.targeting.*",
      "digital-ads.creative.generate",
      "digital-ads.creative.generate_brief",
      "digital-ads.creative.upload",
      "digital-ads.creative.list",
      "digital-ads.creative.analyze",
      "digital-ads.creative.score_assets",
      "digital-ads.report.performance",
      "digital-ads.report.creative",
      "digital-ads.signal.*",
      "digital-ads.pacing.check",
      "digital-ads.alert.anomaly_scan",
      "digital-ads.alert.budget_forecast",
      "digital-ads.memory.*",
      "digital-ads.compliance.review_status",
      "digital-ads.compliance.audit",
      "crm.*"
    ],
    "exclude": [
      "customer-engagement.pipeline.*",
      "digital-ads.campaign.setup_guided",
      "digital-ads.campaign.update_objective"
    ],
    "aliases": {
      "book_appointment": "customer-engagement.appointment.book",
      "cancel_appointment": "customer-engagement.appointment.cancel",
      "reschedule_appointment": "customer-engagement.appointment.reschedule",
      "send_reminder": "customer-engagement.reminder.send",
      "log_treatment": "customer-engagement.treatment.log",
      "request_review": "customer-engagement.review.request",
      "respond_to_review": "customer-engagement.review.respond",
      "start_cadence": "customer-engagement.cadence.start",
      "stop_cadence": "customer-engagement.cadence.stop",
      "qualify_lead": "customer-engagement.lead.qualify",
      "score_lead": "customer-engagement.lead.score",
      "update_stage": "customer-engagement.journey.update_stage",
      "score_ltv": "customer-engagement.contact.score_ltv",
      "handle_objection": "customer-engagement.conversation.handle_objection",
      "escalate": "customer-engagement.conversation.escalate",
      "check_ads": "digital-ads.funnel.diagnose",
      "create_campaign": "digital-ads.campaign.create",
      "pause_campaign": "digital-ads.campaign.pause",
      "adjust_budget": "digital-ads.campaign.adjust_budget"
    }
  },

  "governance": {
    "profile": "guarded",
    "policyOverrides": [
      {
        "name": "clinic-high-risk-cancellation",
        "description": "Require approval for appointment cancellations within 24 hours",
        "rule": {
          "actionType": "customer-engagement.appointment.cancel"
        },
        "effect": "require_approval"
      },
      {
        "name": "clinic-review-response-approval",
        "description": "Public review responses always require manager approval",
        "rule": {
          "actionType": "customer-engagement.review.respond"
        },
        "effect": "require_approval"
      },
      {
        "name": "clinic-campaign-create-approval",
        "description": "Campaign creation always requires owner approval",
        "rule": {
          "actionType": "digital-ads.campaign.create"
        },
        "effect": "require_approval"
      }
    ],
    "spendLimits": {
      "dailyUsd": 200,
      "weeklyUsd": 1000,
      "monthlyUsd": 3000
    },
    "approvalRouting": {
      "channelPreference": "telegram"
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are an AI operator for a dental clinic. You manage ad campaigns to attract new patients and handle speed-to-lead responses when enquiries come in. You also help staff with appointment booking and patient communications. Use clear, professional language appropriate for a healthcare setting.",
    "replyTemplates": {
      "appointment_booked": "Appointment confirmed for {{contactName}} on {{date}} at {{time}}.",
      "appointment_cancelled": "Appointment for {{contactName}} on {{date}} has been cancelled.",
      "reminder_sent": "Reminder sent to {{contactName}} for their appointment on {{date}}.",
      "treatment_logged": "Treatment record saved for {{contactName}}: {{treatmentType}}.",
      "review_requested": "Review request sent to {{contactName}}.",
      "cadence_started": "Outreach cadence started for {{contactName}}.",
      "cadence_stopped": "Outreach cadence stopped for {{contactName}}.",
      "campaign_created": "Campaign '{{campaignName}}' created with ${{dailyBudget}}/day budget.",
      "campaign_paused": "Campaign '{{campaignName}}' has been paused.",
      "budget_adjusted": "Budget for '{{campaignName}}' updated to ${{newBudget}}/day."
    },
    "terminology": {
      "campaign": "ad campaign",
      "lead": "prospective patient",
      "deal": "treatment case",
      "contact": "patient",
      "pipeline": "patient journey",
      "stage": "journey stage",
      "activity": "interaction"
    },
    "welcomeMessage": "Welcome to {{businessName}}! I'm your AI operator. I manage your ad campaigns to attract new patients and respond to enquiries instantly.\n\nI can also help with appointments, reminders, and patient records.\n\nType 'help' to see everything I can do, or just tell me what you need!"
  },

  "funnelMode": "lead_gen",
  "leadChannel": "telegram",

  "playbooks": [
    {
      "id": "new-patient-intake",
      "name": "New Patient Intake",
      "trigger": "new patient intake",
      "steps": [
        { "actionType": "customer-engagement.lead.qualify" },
        { "actionType": "customer-engagement.lead.score" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.cadence.start",
          "parameterDefaults": { "cadenceType": "new-patient-welcome" }
        }
      ]
    },
    {
      "id": "post-treatment-followup",
      "name": "Post-Treatment Follow-up",
      "trigger": "post treatment follow up",
      "steps": [
        { "actionType": "customer-engagement.treatment.log" },
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "follow-up" }
        },
        { "actionType": "customer-engagement.review.request" }
      ]
    },
    {
      "id": "appointment-reschedule",
      "name": "Reschedule Appointment",
      "trigger": "reschedule appointment",
      "steps": [
        { "actionType": "customer-engagement.appointment.cancel" },
        { "actionType": "customer-engagement.appointment.book" },
        {
          "actionType": "customer-engagement.reminder.send",
          "parameterDefaults": { "reminderType": "rescheduled" }
        }
      ]
    }
  ],

  "requiredCartridges": ["digital-ads", "customer-engagement", "crm"],

  "channels": {
    "primary": "telegram",
    "enabled": ["telegram", "whatsapp", "instagram", "messenger"]
  },

  "campaignTemplates": [
    {
      "id": "teeth-whitening-leads",
      "name": "Teeth Whitening — Lead Gen",
      "service": "Teeth Whitening",
      "objective": "leads",
      "suggestedDailyBudget": 15,
      "targetingHints": ["cosmetic dentistry interest", "25-54 age range", "10mi radius"],
      "creativeAngles": ["confidence boost", "professional results", "limited-time offer"]
    },
    {
      "id": "general-dentistry-awareness",
      "name": "General Dentistry — New Patients",
      "service": "General Dentistry",
      "objective": "leads",
      "suggestedDailyBudget": 10,
      "targetingHints": ["dental care interest", "families", "10mi radius"],
      "creativeAngles": ["family-friendly", "modern facilities", "gentle care"]
    },
    {
      "id": "emergency-dental",
      "name": "Emergency Dental — Urgent Leads",
      "service": "Emergency Dental",
      "objective": "leads",
      "suggestedDailyBudget": 20,
      "targetingHints": ["dental emergency", "toothache", "5mi radius"],
      "creativeAngles": ["same-day availability", "pain relief", "no wait"]
    }
  ],

  "conversionValueMap": {
    "inquiry": 0,
    "qualified": 5,
    "booked": 50,
    "completed": 280
  },

  "config": {
    "bannedPhrases": ["competitor_name", "guaranteed results", "100% success"],
    "bookingUrl": "https://calendly.com/your-clinic"
  }
}
