{
  "id": "commerce",
  "name": "E-Commerce",
  "version": "1.0.0",
  "description": "Vertical skin for e-commerce businesses. Exposes digital ads management in conversions mode with catalog and creative tools. No speed-to-lead — optimizes for direct purchases.",

  "tools": {
    "include": [
      "digital-ads.platform.*",
      "digital-ads.health.*",
      "digital-ads.snapshot.*",
      "digital-ads.funnel.*",
      "digital-ads.portfolio.*",
      "digital-ads.structure.*",
      "digital-ads.campaign.*",
      "digital-ads.adset.*",
      "digital-ads.ad.*",
      "digital-ads.targeting.*",
      "digital-ads.creative.generate",
      "digital-ads.creative.generate_brief",
      "digital-ads.creative.upload",
      "digital-ads.creative.list",
      "digital-ads.creative.analyze",
      "digital-ads.creative.score_assets",
      "digital-ads.report.performance",
      "digital-ads.report.creative",
      "digital-ads.signal.*",
      "digital-ads.pacing.check",
      "digital-ads.alert.anomaly_scan",
      "digital-ads.alert.budget_forecast",
      "crm.*"
    ],
    "exclude": [
      "customer-engagement.*",
      "digital-ads.campaign.setup_guided",
      "digital-ads.campaign.update_objective"
    ],
    "aliases": {
      "check_ads": "digital-ads.funnel.diagnose",
      "create_campaign": "digital-ads.campaign.create",
      "pause_campaign": "digital-ads.campaign.pause",
      "adjust_budget": "digital-ads.campaign.adjust_budget",
      "run_ads": "digital-ads.campaign.create",
      "check_performance": "digital-ads.funnel.diagnose"
    }
  },

  "governance": {
    "profile": "guarded",
    "policyOverrides": [
      {
        "name": "commerce-campaign-create-approval",
        "description": "Campaign creation always requires owner approval",
        "rule": {
          "actionType": "digital-ads.campaign.create"
        },
        "effect": "require_approval"
      }
    ],
    "spendLimits": {
      "dailyUsd": 500,
      "weeklyUsd": 2500,
      "monthlyUsd": 8000
    },
    "approvalRouting": {
      "channelPreference": "telegram"
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are an AI operator for an e-commerce business. You manage ad campaigns to drive product sales and optimize for return on ad spend. Focus on conversion performance, creative fatigue, and budget efficiency.",
    "replyTemplates": {
      "campaign_created": "Campaign '{{campaignName}}' created with ${{dailyBudget}}/day budget.",
      "campaign_paused": "Campaign '{{campaignName}}' has been paused.",
      "budget_adjusted": "Budget for '{{campaignName}}' updated to ${{newBudget}}/day.",
      "alert_anomaly": "Alert: {{anomalyType}} detected on '{{campaignName}}' — {{details}}."
    },
    "terminology": {
      "campaign": "ad campaign",
      "lead": "customer",
      "deal": "order",
      "contact": "customer",
      "pipeline": "purchase funnel",
      "stage": "funnel stage",
      "activity": "interaction"
    },
    "welcomeMessage": "Welcome to {{businessName}}! I'm your AI ad operator. I manage your campaigns to drive sales and maximize your return on ad spend.\n\nType 'help' to see everything I can do, or just tell me what you need!"
  },

  "funnelMode": "conversions",
  "leadChannel": null,

  "playbooks": [],

  "requiredCartridges": ["digital-ads", "crm"],

  "channels": {
    "primary": "telegram",
    "enabled": ["telegram", "whatsapp"]
  },

  "conversionValueMap": {
    "purchased": "dynamic"
  },

  "stageDefinitions": {
    "interested": {
      "label": "Browsing",
      "criteria": "Product inquiry or quote request",
      "typicalDuration": "1-3 days"
    },
    "qualified": {
      "label": "Serious Buyer",
      "criteria": "Budget confirmed, requirements clear",
      "typicalDuration": "2-7 days"
    },
    "quoted": {
      "label": "Quote Sent",
      "criteria": "Formal quote or proposal shared",
      "typicalDuration": "3-14 days"
    },
    "booked": { "label": "Order Placed", "criteria": "Order confirmed, deposit paid" },
    "showed": { "label": "Delivered", "criteria": "Product/service delivered" },
    "won": { "label": "Paid in Full", "criteria": "Full payment received" },
    "lost": { "label": "Lost", "criteria": "Cancelled or abandoned" },
    "nurturing": { "label": "Nurturing", "criteria": "Re-engagement or upsell sequence" }
  },
  "dormancyThresholdDays": 30,
  "reopenWindowDays": 60,
  "fallbackSLA": {
    "urgent": { "dueDurationHours": 4 },
    "high": { "dueDurationHours": 12 },
    "medium": { "dueDurationHours": 24 },
    "low": { "dueDurationHours": 72 }
  },

  "config": {
    "bannedPhrases": []
  }
}
