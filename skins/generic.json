{
  "id": "generic",
  "name": "Generic Business",
  "version": "1.0.0",
  "description": "Generic skin for any business type. Exposes core digital ads management and CRM tools with auto-detected funnel mode. Minimal vertical assumptions.",

  "tools": {
    "include": [
      "digital-ads.platform.*",
      "digital-ads.health.*",
      "digital-ads.snapshot.*",
      "digital-ads.funnel.*",
      "digital-ads.portfolio.*",
      "digital-ads.structure.*",
      "digital-ads.campaign.*",
      "digital-ads.adset.*",
      "digital-ads.ad.*",
      "digital-ads.targeting.*",
      "digital-ads.creative.generate",
      "digital-ads.creative.generate_brief",
      "digital-ads.creative.upload",
      "digital-ads.creative.list",
      "digital-ads.creative.analyze",
      "digital-ads.creative.score_assets",
      "digital-ads.report.performance",
      "digital-ads.report.creative",
      "digital-ads.signal.*",
      "digital-ads.pacing.check",
      "digital-ads.alert.anomaly_scan",
      "digital-ads.alert.budget_forecast",
      "crm.*"
    ],
    "exclude": ["digital-ads.campaign.setup_guided", "digital-ads.campaign.update_objective"],
    "aliases": {
      "check_ads": "digital-ads.funnel.diagnose",
      "create_campaign": "digital-ads.campaign.create",
      "pause_campaign": "digital-ads.campaign.pause",
      "adjust_budget": "digital-ads.campaign.adjust_budget"
    }
  },

  "governance": {
    "profile": "guarded",
    "policyOverrides": [
      {
        "name": "generic-campaign-create-approval",
        "description": "Campaign creation always requires owner approval",
        "rule": {
          "actionType": "digital-ads.campaign.create"
        },
        "effect": "require_approval"
      }
    ],
    "spendLimits": {
      "dailyUsd": 300,
      "weeklyUsd": 1500,
      "monthlyUsd": 5000
    },
    "approvalRouting": {
      "channelPreference": "telegram"
    }
  },

  "language": {
    "locale": "en",
    "interpreterSystemPrompt": "You are an AI operator that manages digital advertising for a business. You help create, monitor, and optimize ad campaigns. Be clear and concise in your communications.",
    "replyTemplates": {
      "campaign_created": "Campaign '{{campaignName}}' created with ${{dailyBudget}}/day budget.",
      "campaign_paused": "Campaign '{{campaignName}}' has been paused.",
      "budget_adjusted": "Budget for '{{campaignName}}' updated to ${{newBudget}}/day."
    },
    "terminology": {
      "campaign": "ad campaign",
      "lead": "lead",
      "deal": "deal",
      "contact": "contact",
      "pipeline": "pipeline",
      "stage": "stage",
      "activity": "activity"
    },
    "welcomeMessage": "Welcome to {{businessName}}! I'm your AI ad operator. I can help you create, monitor, and optimize your ad campaigns.\n\nType 'help' to see everything I can do, or just tell me what you need!"
  },

  "funnelMode": "lead_gen",
  "funnelModeHint": "auto-detect from onboarding: ask 'Do customers contact you before buying?' → lead_gen, otherwise → conversions",

  "playbooks": [],

  "requiredCartridges": ["digital-ads", "crm"],

  "channels": {
    "primary": "telegram",
    "enabled": ["telegram", "whatsapp"]
  },

  "conversionValueMap": {
    "inquiry": 0,
    "qualified": 5,
    "converted": 50
  },

  "stageDefinitions": {
    "interested": {
      "label": "New Lead",
      "criteria": "Initial contact or inquiry",
      "typicalDuration": "1-3 days"
    },
    "qualified": {
      "label": "Qualified",
      "criteria": "Needs confirmed, budget discussed",
      "typicalDuration": "3-7 days"
    },
    "quoted": { "label": "Quoted", "criteria": "Pricing shared", "typicalDuration": "3-14 days" },
    "booked": { "label": "Booked", "criteria": "Appointment or delivery confirmed" },
    "showed": { "label": "Completed", "criteria": "Service delivered" },
    "won": { "label": "Paid", "criteria": "Payment received" },
    "lost": { "label": "Lost", "criteria": "Declined or unresponsive" },
    "nurturing": { "label": "Nurturing", "criteria": "Re-engagement sequence" }
  },
  "dormancyThresholdDays": 30,
  "reopenWindowDays": 90,
  "fallbackSLA": {
    "urgent": { "dueDurationHours": 4 },
    "high": { "dueDurationHours": 12 },
    "medium": { "dueDurationHours": 24 },
    "low": { "dueDurationHours": 72 }
  },

  "config": {
    "bannedPhrases": []
  }
}
