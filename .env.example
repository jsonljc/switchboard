# Node environment (defaults to "development")
NODE_ENV=development

# API Server
PORT=3000
HOST=0.0.0.0
ENABLE_SWAGGER=false

# CORS — comma-separated origins (leave empty to allow all in development)
CORS_ORIGIN=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# API Authentication — comma-separated API keys (leave empty to disable auth in development)
API_KEYS=
# Optional JSON metadata attached to API keys
API_KEY_METADATA=

# Chat Server
CHAT_PORT=3001

# Database (used by docker-compose)
# Pool params: connection_limit controls max connections, pool_timeout is wait time in seconds
DATABASE_URL=postgresql://switchboard:switchboard@localhost:5432/switchboard?connection_limit=10&pool_timeout=10
# Docker Compose Postgres credentials (prod compose uses these to construct DATABASE_URL)
POSTGRES_USER=switchboard
POSTGRES_PASSWORD=switchboard
POSTGRES_DB=switchboard

# Redis (used for rate limiting, idempotency, BullMQ)
REDIS_URL=redis://localhost:6379
# Redis password (prod compose uses --requirepass with this value)
REDIS_PASSWORD=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Messaging — Slack
SLACK_BOT_TOKEN=

# Messaging — WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Webhook Rate Limiting (chat server)
WEBHOOK_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Meta Ads API
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
META_PIXEL_ID=

# Google Ads API
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# TikTok Ads API
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# HubSpot CRM
HUBSPOT_ACCESS_TOKEN=

# Skin (vertical deployment configuration, e.g. "clinic", "gym")
SKIN_ID=
# Business profile (per-instance knowledge, e.g. "clinic-demo", "gym-demo")
# Profiles are loaded from the profiles/ directory
PROFILE_ID=
# Lead bot mode — set to "true" to route messages through qualification/booking flows
# instead of the owner/operator interpreter pipeline. Requires SKIN_ID to be set.
LEAD_BOT_MODE=
ANTHROPIC_API_KEY=
# Voyage AI — real embeddings for knowledge base (zero-vector stubs used when not set)
VOYAGE_API_KEY=

# Optional: delegate to centralized Switchboard API instead of embedded orchestrator
SWITCHBOARD_API_URL=
SWITCHBOARD_API_KEY=

# Managed Provisioning (Track B)
CHAT_PUBLIC_URL=http://localhost:3001
CHAT_INTERNAL_URL=http://localhost:3001
INTERNAL_API_SECRET=
INTERNAL_SETUP_SECRET=

# Dashboard
DASHBOARD_PORT=3002
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=
# Set to "true" to bypass auth during local development
NEXT_PUBLIC_DEV_BYPASS_AUTH=
# Email provider (magic link) — OPTIONAL
# Credentials login (email + password) works without SMTP.
# To enable magic link, configure the EMAIL_SERVER_* vars below and set:
# NEXT_PUBLIC_SMTP_CONFIGURED=true
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@switchboard.app
API_KEY_ENCRYPTION_SECRET=

# Credential encryption (required when DATABASE_URL is set and connections are stored)
CREDENTIALS_ENCRYPTION_KEY=

# Stripe (Payments cartridge)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Booking Webhook (HMAC signature verification)
BOOKING_WEBHOOK_SECRET=

# MCP Server API keys — comma-separated keys for MCP client authentication
MCP_API_KEYS=
# MCP Server API key for delegating to Switchboard API (used when SWITCHBOARD_API_URL is set)
MCP_API_KEY=

# Telemetry (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=switchboard

# Session-scoped JWT for session auth (min 32 chars recommended)
SESSION_TOKEN_SECRET=
