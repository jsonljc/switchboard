# Node environment (defaults to "development")
NODE_ENV=development

# API Server
PORT=3000
HOST=0.0.0.0
ENABLE_SWAGGER=false

# CORS — comma-separated origins (leave empty to allow all in development)
CORS_ORIGIN=

# Logging — controls log verbosity (default: "info" in production, "debug" in development)
# Options: "fatal", "error", "warn", "info", "debug", "trace"
LOG_LEVEL=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Per-endpoint HTTP rate limit overrides — protect approval responses and action execution
# from being starved by high-frequency reads sharing the global window above.
# Distinct from APPROVAL_RATE_LIMIT_MAX below: these are per-IP HTTP edge limits,
# that is per-responder semantic limit applied inside PlatformLifecycle.
APPROVAL_HTTP_RATE_LIMIT_MAX=300
APPROVAL_HTTP_RATE_LIMIT_WINDOW_MS=60000
EXECUTE_HTTP_RATE_LIMIT_MAX=300
EXECUTE_HTTP_RATE_LIMIT_WINDOW_MS=60000

# Per-responder approval response cap — anti-rubber-stamping limit on how many approve/patch
# actions a single user can submit in a window. Wired in apps/api/src/app.ts; enforced inside
# packages/core/src/platform/platform-lifecycle.ts. Leave unset to disable.
APPROVAL_RATE_LIMIT_MAX=
APPROVAL_RATE_LIMIT_WINDOW_MS=60000

# API Authentication — comma-separated API keys (leave empty to disable auth in development)
API_KEYS=
# Optional JSON metadata attached to API keys
API_KEY_METADATA=
# In-process cache TTL (ms) for DB-validated dashboard API keys. Short so revoked
# keys stop authenticating promptly. Default 5000; set 0 to re-validate every request.
DB_KEY_CACHE_TTL_MS=5000

# Chat Server
CHAT_PORT=3001

# Database (used by docker-compose)
# Pool params: connection_limit controls max connections, pool_timeout is wait time in seconds
DATABASE_URL=postgresql://switchboard:switchboard@localhost:5432/switchboard?connection_limit=10&pool_timeout=10
# Docker Compose Postgres credentials (prod compose uses these to construct DATABASE_URL)
POSTGRES_USER=switchboard
POSTGRES_PASSWORD=switchboard
POSTGRES_DB=switchboard

# Redis (used for rate limiting, idempotency, BullMQ)
REDIS_URL=redis://localhost:6379
# Redis password (prod compose uses --requirepass with this value)
REDIS_PASSWORD=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Operator Telegram chat ID for escalation/handoff notifications
ESCALATION_CHAT_ID=
# Operator email used for skill-mode escalation routing (single recipient).
ESCALATION_EMAIL=
# Comma-separated list of email recipients for breach notifications.
ESCALATION_EMAIL_RECIPIENTS=
# When "true", emit operator alerts on SLA breach. Defaults to off.
ESCALATION_NOTIFY_ON_BREACH=
# SLA window (minutes) after which a pending escalation breaches. Default: 60.
ESCALATION_SLA_MINUTES=

# Operator alert webhook (Slack-shaped). HMAC signed with the secret below.
OPERATOR_ALERT_WEBHOOK_URL=
OPERATOR_ALERT_WEBHOOK_SECRET=

# Single-tenant chat deployment overrides (used by static-deployment-resolver).
# Defaults: organizationId="default", skillSlug="sales-pipeline".
ORGANIZATION_ID=
SKILL_SLUG=

# Approval governance — when "true", the same operator can approve their own
# pending action. Off by default.
ALLOW_SELF_APPROVAL=

# Per-IP rate limit on POST /recommendations/:id/act (anti-flood).
RECOMMENDATION_ACT_RATE_LIMIT_MAX=
RECOMMENDATION_ACT_RATE_LIMIT_WINDOW_MS=

# Max concurrent skill sessions allowed by the API session bootstrap.
MAX_CONCURRENT_SESSIONS=

# Set to "true" to bypass dashboard auth in development.
# Mirrors NEXT_PUBLIC_DEV_BYPASS_AUTH but evaluated server-side.
DEV_BYPASS_AUTH=

# Messaging — Slack
SLACK_BOT_TOKEN=
# Slack — signing secret used to verify incoming webhook requests
# (HMAC-SHA256). Generated in Slack app config → Basic Information.
SLACK_SIGNING_SECRET=
# Slack conversation (channel id C... or user id U... for a DM) that
# parked-approval Approve/Reject messages post to. Requires SLACK_BOT_TOKEN to
# be the bot token of the SAME Slack app as the org's managed Slack channel
# (interactivity must reach the managed webhook). Unset = notifications off.
SLACK_APPROVAL_CHANNEL=

# Messaging — WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
# Per-tenant WhatsApp Cloud API token used by the lead-greeting workflow.
WHATSAPP_ACCESS_TOKEN=
# Permanent token for centrally-issued WhatsApp Graph API calls.
WHATSAPP_GRAPH_TOKEN=

# WhatsApp Tech Provider (Embedded Signup)
META_APP_ID=                   # Meta App ID for JS SDK
META_APP_SECRET=               # Meta App secret used for webhook signature verification
META_CONFIG_ID=                # Facebook Login configuration ID for Embedded Signup
META_SYSTEM_USER_TOKEN=        # Permanent SUAT for all client WABAs
META_SYSTEM_USER_ID=           # System User ID for assigned_users calls
META_GRAPH_VERSION=v21.0       # Graph API version pin. Override here if a newer/older version is needed.
META_OAUTH_REDIRECT_URI=       # Override OAuth redirect URI used by Inngest provisioning.
META_WEBHOOK_VERIFY_TOKEN=     # Verify token for Meta webhook GET handshake.
META_CAPI_ACCESS_TOKEN=        # Conversions API access token used by the bootstrap conversion bus.

# Dashboard — WhatsApp Embedded Signup (exposed to browser)
NEXT_PUBLIC_META_APP_ID=       # Same as META_APP_ID
NEXT_PUBLIC_META_CONFIG_ID=    # Same as META_CONFIG_ID

# Webhook Rate Limiting (chat server)
WEBHOOK_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Allow Alex re-engagement marketing template sends (default off; flip with Meta-approved template)
FOLLOWUP_ALLOW_MARKETING_TEMPLATE=
ANTHROPIC_API_KEY=
# Optional: override the Claude model the creative pipeline (Mira polished + UGC)
# uses for every stage. Unset or empty falls back to the package default
# (claude-sonnet-4-6). Must be a valid Anthropic model id or creative jobs fail
# fast at the call seam (packages/creative-pipeline/.../call-claude.ts).
CREATIVE_PIPELINE_MODEL=
# OpenAI — reference image generation for storyboard stage (optional)
OPENAI_API_KEY=
# Voyage AI — real embeddings for knowledge base (zero-vector stubs used when not set)
VOYAGE_API_KEY=

# Optional: legacy single-tenant "delegate to central API" credential. NOT used by the
# managed-channel chat-to-API ingress hop, which authenticates with INTERNAL_API_SECRET (F-15).
# (SWITCHBOARD_API_URL is documented below in the Dashboard section.)
SWITCHBOARD_API_KEY=

# Managed Provisioning (Track B)
CHAT_PUBLIC_URL=http://localhost:3001
CHAT_INTERNAL_URL=http://localhost:3001
# Public chat origin used when emitting widget embed snippets and provision
# completion URLs. Local dev: http://localhost:3001.
CHAT_SERVER_URL=http://localhost:3001
# Server-to-server chat URL used by api/provision flows.
SWITCHBOARD_CHAT_URL=http://localhost:3001
# Shared chat<->api service secret. REQUIRED when DATABASE_URL is set (managed-channel mode):
# authenticates the chat-to-API ingress hop (F-15) + provision-notify + chat approval bridge.
# Use the SAME value for the api and chat services. The chat server refuses to boot in
# managed mode without it.
INTERNAL_API_SECRET=
INTERNAL_SETUP_SECRET=

# Dashboard
DASHBOARD_PORT=3002
# Dashboard's server-side base URL for the Switchboard API.
# Consumed by apps/dashboard's Next.js API routes (see apps/dashboard/src/lib/get-api-client.ts).
# The browser does not call the API directly — calls are proxied server-side through
# Next.js API routes, so this is NOT prefixed with NEXT_PUBLIC_.
# Local dev: http://localhost:3000
# Production: the public Render URL of the api service.
SWITCHBOARD_API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=
# Set to "true" to bypass auth during local development
NEXT_PUBLIC_DEV_BYPASS_AUTH=
# Browser-visible base URLs for the dashboard. Local dev defaults match
# SWITCHBOARD_API_URL / DASHBOARD_URL above.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3002
# Deploy-environment label surfaced in the UI ("local", "preview", "production").
NEXT_PUBLIC_DEPLOY_ENV=local
# Flip to "true" once Google OAuth client IDs are configured (enables the
# "Sign in with Google" button on the login page).
NEXT_PUBLIC_GOOGLE_AUTH_CONFIGURED=
# Stripe billing toggles for the marketing/upgrade surfaces. Leave empty until
# a real Stripe account + price IDs exist.
NEXT_PUBLIC_STRIPE_ENABLED=
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_SCALE=
# Controls registration mode:
#   "waitlist" — show waitlist form, no signup
#   "beta"     — invite-only, requires invite code
#   "public"   — open signup for all
NEXT_PUBLIC_LAUNCH_MODE=public

# Mercury Tools feature flags — set to "true" to enable each Tools ▾ route
#
# Local-readiness contract: each flag's default below matches
# scripts/env-allowlist.live-flag-matrix.json. CI fails if .env.example drifts.
#
# /contacts:    backend shipped (PR-C2 #486); seed-dev-data populates rows.
# /activity:    audit-log surface; seed-dev-data backfills entries.
# /approvals:   first-class architecture per docs/DOCTRINE.md.
# /automations: backend shipped (#406); seed-dev-data populates rows.
# /reports:     launch blocked on Meta Ads Connection + issue #472.
#               Stays fixture-mode locally; reports-page.tsx renders a
#               visible "demo data" banner when this flag is not "true".
NEXT_PUBLIC_CONTACTS_LIVE=true
NEXT_PUBLIC_AUTOMATIONS_LIVE=true
NEXT_PUBLIC_ACTIVITY_LIVE=true
NEXT_PUBLIC_REPORTS_LIVE=false
NEXT_PUBLIC_APPROVALS_LIVE=true

# Email — Resend API (used for verification emails and escalation notifications)
RESEND_API_KEY=
EMAIL_FROM=noreply@switchboard.app

# Email provider (magic link) — OPTIONAL
# Credentials login (email + password) works without SMTP.
# To enable magic link, configure the EMAIL_SERVER_* vars below and set
# NEXT_PUBLIC_SMTP_CONFIGURED=true (browser-visible flag toggling the UI).
NEXT_PUBLIC_SMTP_CONFIGURED=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=

# Google Calendar OAuth — for self-serve calendar connection
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/connections/google-calendar/callback

# Credential encryption (required when DATABASE_URL is set and connections are stored)
CREDENTIALS_ENCRYPTION_KEY=

# Telemetry (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=switchboard

# Session-scoped JWT for session auth (min 32 chars recommended)
SESSION_TOKEN_SECRET=

# Inngest async-job orchestration.
# Local dev: leave blank — `inngest dev` connects to the API's /api/inngest endpoint
# without signing.
# Production (Inngest Cloud): both keys are REQUIRED. Generated in the Inngest
# Cloud dashboard at https://app.inngest.com/<workspace>/settings/signing-keys.
# Set on the `api` service in Render.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Creative Pipeline — Video Production (Stage 5)
KLING_API_KEY=            # Kling AI API key for video generation
HEYGEN_API_KEY=           # HeyGen API key for avatar UGC (slice-3; unset = avatar routing dormant)
ELEVENLABS_API_KEY=       # ElevenLabs API key for voice synthesis (Pro tier)

# Creative Pipeline — SSRF allowlist for outbound media downloads
# Comma-separated regex patterns matched against URL hostnames in
# downloadClips / WhisperClient.transcribe / frame-QA + durable-asset
# downloads. Default if unset:
#   \.amazonaws\.com$,\.cloudfront\.net$
# Operators SHOULD narrow this to the deployment's known media bucket
# (e.g. ^my-bucket\.s3\.us-east-1\.amazonaws\.com$). Patterns are
# evaluated case-insensitively. URLs must be https:// and must not
# resolve to private IPs (10/8, 172.16/12, 192.168/16, 127/8,
# 169.254/16, ::1, fc00::/7) — those are rejected unconditionally.
# UGC PREREQUISITE (slice-3): the video provider CDN hosts MUST be listed or
# frame-QA degrades to human review and the durable-asset upload (and so
# publish) fails for those clips: add the Kling CDN host, and the HeyGen CDN
# host (\.heygen\.ai$ class) when HEYGEN_API_KEY is set.
CREATIVE_PIPELINE_ALLOWED_HOSTS=

# Creative Pipeline — Durable asset storage (S3-compatible; Cloudflare R2 by default)
# Where the polished pipeline's assembled MP4 + thumbnail are uploaded so a
# completed+kept creative is publishable (CreativeJob.durableAssetUrl). If unset,
# rendering still works but assets are not durable and creative.job.publish fails
# loud CREATIVE_ASSET_NOT_DURABLE. The bucket MUST be configured for public read
# at CREATIVE_ASSET_PUBLIC_BASE_URL (objects use unguessable keys). For Cloudflare
# R2, set CREATIVE_ASSET_S3_ENDPOINT and keep CREATIVE_ASSET_REGION="auto". For
# AWS S3, leave the endpoint blank and set a REAL region (e.g. us-east-1) — the
# committed default "auto" is an R2-ism that AWS rejects.
CREATIVE_ASSET_BUCKET=
CREATIVE_ASSET_S3_ENDPOINT=
CREATIVE_ASSET_REGION=auto
CREATIVE_ASSET_ACCESS_KEY_ID=
CREATIVE_ASSET_SECRET_ACCESS_KEY=
CREATIVE_ASSET_PUBLIC_BASE_URL=

# Google Calendar (optional — enables real calendar booking for Alex)
# Service account JSON (single line, or path to file)
GOOGLE_CALENDAR_CREDENTIALS=
# Calendar ID to book on (e.g. primary, or user@domain.com)
GOOGLE_CALENDAR_ID=

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook / Meta Ads OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# In production, replace with: https://YOUR_DOMAIN/api/connections/facebook/callback
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/connections/facebook/callback

# Meta Pixel ID — public-safe identifier surfaced in browser-side pixel events.
# Not a secret but operator must enter it per Meta Ads setup.
META_PIXEL_ID=

# Dashboard URL (for OAuth callback redirects)
DASHBOARD_URL=http://localhost:3002

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# Error Monitoring — Sentry (optional, gracefully skipped if not set)
SENTRY_DSN_SERVER=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: webhook URL (Slack incoming webhook or compatible) for chat health alerts.
# Receives Slack-shaped { text } payloads on managed-channel active↔error transitions.
# Unset = alerts disabled.
ALERT_WEBHOOK_URL=

# Riley PR-3 outcome-attribution kill-switch. Default false until rollout.
RILEY_OUTCOME_ATTRIBUTION_ENABLED=false

# Phase-C: Riley pause self-submission initiator (cron-level kill switch; the
# per-org governanceSettings.pauseSelfExecutionEnabled flag must ALSO be true,
# flipped only via scripts/riley-pause-flag.ts). Default off: deploy dark.
RILEY_PAUSE_SELF_EXECUTION_ENABLED=false

# Mira slice-2 per-creative attribution sweep kill-switch. Default off: deploy
# dark, enable deliberately once a published creative is activated in Ads Manager.
CREATIVE_ATTRIBUTION_ENABLED=false

# Alex per-turn model router kill-switch. Default false until the #672 eval
# baseline is locked; flip to true to enable Haiku/Sonnet/Opus per-turn tiering.
ALEX_MODEL_ROUTER_ENABLED=false

# Mira slice-4 weekly self-brief loop kill-switch. Default off: deploy dark,
# enable deliberately per the spec's flip checklist (org must also be
# Mira-enabled, seeded, and billing-entitled).
MIRA_SELF_BRIEF_ENABLED=false

# Mira slice-4 riley-handoff brief enrichment kill-switch. Default off: the
# handoff carries the shipped BusinessFacts synthesis until enabled; on, the
# brain composes the brief BEFORE the approval park (fallback on any failure).
MIRA_HANDOFF_BRIEF_ENRICHMENT_ENABLED=false
