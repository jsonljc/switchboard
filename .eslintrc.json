{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "max-lines": ["warn", { "max": 400, "skipBlankLines": true, "skipComments": true }],
    "complexity": ["warn", 15]
  },
  "ignorePatterns": ["dist", "node_modules", "coverage"],
  "overrides": [
    {
      "files": ["packages/schemas/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/*"],
                "message": "schemas is a leaf package and cannot import any @switchboard/* package."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/cartridge-sdk/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/core", "@switchboard/core/*"],
                "message": "cartridge-sdk cannot import from core."
              },
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "cartridge-sdk cannot import from db."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "cartridge-sdk cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/db/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/cartridge-sdk", "@switchboard/cartridge-sdk/*"],
                "message": "db cannot import from cartridge-sdk."
              },
              {
                "group": ["@switchboard/digital-ads", "@switchboard/digital-ads/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/customer-engagement", "@switchboard/customer-engagement/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/payments", "@switchboard/payments/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/crm", "@switchboard/crm/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/quant-trading", "@switchboard/quant-trading/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/revenue-growth", "@switchboard/revenue-growth/*"],
                "message": "db cannot import from cartridges."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "db cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/core/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "core cannot import from db."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "core cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["cartridges/*/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "Cartridges cannot import from db."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "Cartridges cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "Cartridges cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "Cartridges cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "Cartridges cannot import from apps."
              }
            ]
          }
        ]
      }
    }
  ]
}
