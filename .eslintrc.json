{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "max-lines": ["error", { "max": 600, "skipBlankLines": true, "skipComments": true }],
    "complexity": ["warn", 15]
  },
  "ignorePatterns": ["dist", "node_modules", "coverage"],
  "overrides": [
    {
      "files": ["packages/schemas/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/*"],
                "message": "schemas is a leaf package and cannot import any @switchboard/* package."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/creative-pipeline/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/core", "@switchboard/core/*"],
                "message": "creative-pipeline cannot import from core."
              },
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "creative-pipeline cannot import from db."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/ad-optimizer/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/core", "@switchboard/core/*"],
                "message": "ad-optimizer cannot import from core."
              },
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "ad-optimizer cannot import from db."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/cartridge-sdk/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/core", "@switchboard/core/*"],
                "message": "cartridge-sdk cannot import from core."
              },
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "cartridge-sdk cannot import from db."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "cartridge-sdk cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "cartridge-sdk cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/db/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/cartridge-sdk", "@switchboard/cartridge-sdk/*"],
                "message": "db cannot import from cartridge-sdk."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "db cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "db cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/core/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/db", "@switchboard/db/*"],
                "message": "core cannot import from db."
              },
              {
                "group": ["@switchboard/creative-pipeline", "@switchboard/creative-pipeline/*"],
                "message": "core cannot import from creative-pipeline."
              },
              {
                "group": ["@switchboard/ad-optimizer", "@switchboard/ad-optimizer/*"],
                "message": "core cannot import from ad-optimizer."
              },
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "core cannot import from apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "core cannot import from apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["apps/*/src/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@switchboard/api", "@switchboard/api/*"],
                "message": "Apps cannot import from other apps."
              },
              {
                "group": ["@switchboard/chat", "@switchboard/chat/*"],
                "message": "Apps cannot import from other apps."
              },
              {
                "group": ["@switchboard/dashboard", "@switchboard/dashboard/*"],
                "message": "Apps cannot import from other apps."
              },
              {
                "group": ["@switchboard/mcp-server", "@switchboard/mcp-server/*"],
                "message": "Apps cannot import from other apps."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["apps/api/src/routes/**/*.ts"],
      "excludedFiles": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "MemberExpression[property.name='resolveAndPropose']",
            "message": "Use PlatformIngress.submit() instead of orchestrator.resolveAndPropose(). See ingress-convergence design."
          },
          {
            "selector": "CallExpression[callee.property.name='emit'][callee.object.property.name='conversionBus']",
            "message": "Write to OutboxEvent table instead of calling conversionBus.emit() directly. Events must be durable."
          }
        ]
      }
    }
  ]
}
