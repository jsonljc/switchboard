{
  "name": "switchboard",
  "description": "Governed revenue loop for WhatsApp-first clinics: booking and ad operations, receipts, and budget reallocation under one governance gate",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:ready": "npx tsx scripts/dev-ready.ts",
    "predev": "bash scripts/check-env.sh",
    "lint": "turbo lint",
    "local:setup": "npx tsx scripts/local-setup.ts",
    "local:verify": "npx tsx scripts/local-verify.ts",
    "local:verify:fast": "npx tsx scripts/local-verify-fast.ts",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "clean": "turbo clean",
    "reset": "pnpm clean && rm -rf packages/db/node_modules/.prisma node_modules/.prisma && pnpm db:generate && turbo build --filter=@switchboard/db^... --filter=@switchboard/db",
    "typecheck": "turbo typecheck",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"apps/*/src/**/*.ts\"",
    "db:generate": "pnpm --filter @switchboard/db generate",
    "db:migrate": "pnpm --filter @switchboard/db migrate",
    "db:seed": "pnpm --filter @switchboard/db seed",
    "db:check-drift": "bash scripts/check-prisma-drift.sh",
    "prepare": "husky || true",
    "arch:check": "npx tsx scripts/arch-check.ts",
    "preflight": "bash scripts/preflight.sh",
    "reference-audit": "node scripts/reference-audit.mjs",
    "stripe:readiness": "tsx apps/api/scripts/check-stripe-readiness.mts",
    "worktree:init": "bash scripts/worktree-init.sh",
    "archive:superpowers": "bash scripts/archive-superpowers-docs.sh",
    "archive:superpowers:install": "bash scripts/launchd/install-archive-superpowers.sh",
    "audit:validate": "npx tsx scripts/audit-validate-findings.ts",
    "audit:lighthouse": "bash scripts/audit-run-lighthouse.sh",
    "audit:axe": "bash scripts/audit-run-axe.sh",
    "dashboard:preflight": "pnpm --filter @switchboard/schemas build && pnpm --filter @switchboard/db build && pnpm --filter @switchboard/dashboard typecheck",
    "dashboard:release-check": "pnpm dashboard:preflight && pnpm --filter @switchboard/dashboard test && pnpm --filter @switchboard/dashboard build",
    "classifier-eval": "pnpm --filter @switchboard/core classifier-eval",
    "eval:classifier": "tsx evals/claim-classifier/run-eval.ts",
    "eval:alex-conversation": "tsx evals/alex-conversation/run-eval.ts",
    "eval:governance": "tsx evals/governance-decision/run-eval.ts",
    "eval:riley": "tsx evals/riley-recommendation/run-eval.ts",
    "eval:trajectory": "tsx evals/trajectory-grading/run-eval.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "next@<15.5.18": "15.5.18",
      "next@>=16.0.0 <16.2.6": "16.2.6",
      "@opentelemetry/sdk-node@<0.217.0": "0.217.0",
      "@opentelemetry/exporter-prometheus@<0.217.0": "0.217.0",
      "@opentelemetry/auto-instrumentations-node@<0.75.0": "0.75.0",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": "1.14.4",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "flatted@<=3.4.1": "3.4.2",
      "esbuild@<0.28.1": "0.28.1",
      "effect@<3.20.0": "3.20.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "protobufjs@<=7.6.0": "7.6.1",
      "protobufjs@>=8.0.0 <=8.4.0": "8.4.1",
      "@protobufjs/utf8@<=1.1.0": "1.1.1",
      "hono@<4.12.25": "4.12.25",
      "postcss@<8.5.10": "8.5.10",
      "vite@<=6.4.2": "6.4.3",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "ip-address@<=10.1.0": "10.1.1",
      "@anthropic-ai/sdk@>=0.79.0 <0.91.1": "0.91.1",
      "fastify@>=5.3.2 <5.8.5": "5.8.5",
      "fast-uri@<3.1.2": "3.1.2",
      "lodash@>=4.0.0 <4.18.0": "4.18.0",
      "defu@<6.1.5": "6.1.5",
      "undici@>=7.23.0 <7.28.0": "7.28.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-5xrq-8626-4rwp",
        "GHSA-gv7w-rqvm-qjhr",
        "GHSA-p6gq-j5cr-w38f"
      ]
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20",
    "@commitlint/config-conventional": "^19",
    "bcryptjs": "^3.0.3",
    "@switchboard/db": "workspace:*",
    "@switchboard/schemas": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.56.0",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0",
    "yaml": "^2.8.3"
  }
}
