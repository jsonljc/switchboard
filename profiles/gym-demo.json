  "objectionTrees": [
    {
      "category": "price",
      "keywords": ["expensive", "cost", "price", "afford", "cheap", "budget", "money"],
      "response": "We offer a range of membership options to fit different budgets. Our basic membership starts at just $49/month, and we frequently have promotional offers for new members.",
      "followUp": "Would you like to hear about our current membership specials?"
    },
    {
      "category": "timing",
      "keywords": ["busy", "schedule", "time", "later", "wait", "not now"],
      "response": "We're open from 5 AM to 10 PM on weekdays and offer flexible class schedules. Many of our members fit in 30-minute express workouts around their busy schedules.",
      "followUp": "Would you like to see our class schedule to find times that work for you?"
    },
    {
      "category": "intimidation",
      "keywords": [
        "intimidating",
        "nervous",
        "beginner",
        "out of shape",
        "don't know",
        "never been"
      ],
      "response": "We welcome all fitness levels! Our trainers specialize in working with beginners and will create a personalized plan that meets you where you are. No judgment, ever.",
      "followUp": "Would you like to book a free introductory session with one of our trainers?"
    },
    {
      "category": "commitment",
      "keywords": ["contract", "commitment", "cancel", "locked in", "long term"],
      "response": "We offer month-to-month memberships with no long-term contracts. You can cancel anytime with 30 days notice.",
      "followUp": "Would you like to try a free week pass before committing?"
    }
  ],
  "cadenceTemplates": [
    {
      "id": "trial-followup",
      "name": "Trial Follow-up",
      "trigger": "trial_completed",
      "steps": [
        {
          "actionType": "customer-engagement.reminder.send",
          "delayMs": 7200000,
          "messageTemplate": "Post-trial check-in",
          "parameters": {
            "contactId": "{{contactId}}",
            "message": "Hi {{contactName}}, thanks for trying Peak Performance today! How are you feeling? Ready to start your fitness journey with us?"
          }
        },
        {
          "actionType": "customer-engagement.reminder.send",
          "delayMs": 172800000,
          "messageTemplate": "Membership offer",
          "parameters": {
            "contactId": "{{contactId}}",
            "message": "{{contactName}}, we have a special offer for trial members — 20% off your first 3 months! Interested?"
          },
          "condition": { "variable": "signedUp", "operator": "neq", "value": true }
        }
      ]
    }
  ],
  "compliance": {
    "enableHipaaRedactor": false,
    "enableMedicalClaimFilter": false,
    "enableConsentGate": true
  },
  "reviewPlatforms": ["google", "yelp"],
