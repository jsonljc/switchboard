{
  "name": "@switchboard/chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "cli:register-webhook": "tsx src/cli/register-webhook.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@sentry/node": "^10.50.0",
    "@switchboard/ad-optimizer": "workspace:*",
    "@switchboard/cartridge-sdk": "workspace:*",
    "@switchboard/core": "workspace:*",
    "@switchboard/db": "workspace:*",
    "@switchboard/schemas": "workspace:*",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
