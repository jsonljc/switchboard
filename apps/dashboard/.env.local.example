# =============================================================================
# This file mirrors keys from the root `.env`.
# Keys marked SYNC-FROM-ROOT must hold the same values as the root `.env`,
# or auth / encryption will silently fail.
# Run `pnpm local:setup` from repo root to set up env files consistently.
# =============================================================================

# Dashboard
DASHBOARD_PORT=3002

# Dev auth bypass — set to "true" to skip login and use a mock session
# (only honored when NODE_ENV != "production"; requires the dev-user seed to exist)
# DEV_BYPASS_AUTH=true

# NextAuth
NEXTAUTH_URL=http://localhost:3002  # SYNC-FROM-ROOT
NEXTAUTH_SECRET=generate-a-random-secret-here  # SYNC-FROM-ROOT

# Email provider (magic link) — OPTIONAL
# Credentials login (email + password) works without SMTP.
# To enable magic link as a secondary login method, configure SMTP and set
# NEXT_PUBLIC_SMTP_CONFIGURED=true so the UI shows the magic link option.
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-email@example.com
# EMAIL_SERVER_PASSWORD=your-password
# EMAIL_FROM=noreply@switchboard.app
# NEXT_PUBLIC_SMTP_CONFIGURED=true

# Switchboard API
SWITCHBOARD_API_URL=http://localhost:3000  # SYNC-FROM-ROOT
CREDENTIALS_ENCRYPTION_KEY=same-value-as-api-server  # SYNC-FROM-ROOT

# Database (shared with API)
DATABASE_URL=postgresql://switchboard:switchboard@localhost:5432/switchboard?connection_limit=5&pool_timeout=10  # SYNC-FROM-ROOT

# Mercury surface live-data flags. Each defaults to "false" (fixture mode).
# Flip to "true" in the build environment to consume the real API. Inlined
# at build time by Next.js — must be set before the dashboard build, not at
# runtime. Flip after a deliberate staging walkthrough; never on first deploy.
# NEXT_PUBLIC_REPORTS_LIVE=false
NEXT_PUBLIC_CONTACTS_LIVE=true
