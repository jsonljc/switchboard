{
  "name": "@switchboard/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@sentry/node": "^10.50.0",
    "@switchboard/ad-optimizer": "workspace:*",
    "@switchboard/cartridge-sdk": "workspace:*",
    "@switchboard/core": "workspace:*",
    "@switchboard/creative-pipeline": "workspace:*",
    "@switchboard/db": "workspace:*",
    "@switchboard/schemas": "workspace:*",
    "ajv": "^8.18.0",
    "bullmq": "^5.76.2",
    "cron-parser": "^5.5.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "googleapis": "^171.4.0",
    "inngest": "^4.2.5",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.0",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
