  revoked      Boolean   @default(false)
  recordingUri String?
  effectiveAt  DateTime
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  creatorIdentities CreatorIdentity[]

