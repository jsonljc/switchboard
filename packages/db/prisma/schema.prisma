// ---------------------------------------------------------------------------
// Reports v1 — projection cache + PDF cache + pre-Switchboard baseline
// ---------------------------------------------------------------------------

model ReportCache {
  id             String   @id @default(uuid())
  organizationId String
  window         String // "THIS_WEEK" | "THIS_MONTH" | "THIS_QUARTER"
  payload        Json // serialized ReportDataV1
  computedAt     DateTime @default(now())
  expiresAt      DateTime

  @@unique([organizationId, window])
  @@index([expiresAt])
}

model PdfCache {
  id             String   @id @default(uuid())
  organizationId String
  window         String
  pdfBytes       Bytes
  computedAt     DateTime @default(now())
  expiresAt      DateTime

  @@unique([organizationId, window])
  @@index([expiresAt])
}

model PreSwitchboardBaseline {
  id             String   @id @default(uuid())
  organizationId String
  dimension      String // "ads" | "conversations"
  metric         String // "spend" | "leads" | "revenue" | "roas" | "reply_minutes" | "lead_conversion_rate"
  value          Float
  periodStart    DateTime
  periodEnd      DateTime
  capturedAt     DateTime @default(now())

  @@unique([organizationId, dimension, metric, periodStart, periodEnd])
  @@index([organizationId, dimension, metric])
}

// Data-erasure request log. Persisted so a deletion can be audited / verified
// after the fact. Two producers write this row, distinguished by `requestType`:
//   - "meta_data_deletion" (default): the Meta Data Deletion Callback. The
//     user-facing `confirmation_code` is verified at the public status URL the
//     callback returns; the match is cross-org (by phone), so organizationId
//     and requestedByActorId stay null.
//   - "operator_erasure": an operator fulfilling a PDPA right-to-erasure /
//     stop-contacting request for ONE contact in their own org. Carries the
//     organizationId and the authenticated operator in requestedByActorId.
// Deletion runs synchronously, so `status` is "completed" on success; "failed"
// rows are kept for ops triage.
model DataDeletionRequest {
  id                 String    @id @default(uuid())
  userId             String // Meta app-scoped user_id, or "operator:<actorId>" for operator erasures
  confirmationCode   String    @unique
  deletedContactIds  String[]  @default([])
  status             String    @default("completed") // "completed" | "failed"
  failureReason      String?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  // Producer discriminator: "meta_data_deletion" (default, preserves existing
  // Meta rows) | "operator_erasure".
  requestType        String    @default("meta_data_deletion")
  // Org-scope + operator provenance for operator-initiated erasures; null for
  // the cross-org Meta callback.
  organizationId     String?
  requestedByActorId String?

  @@index([userId])
  @@index([organizationId])
}

// Public launch waitlist signups captured before self-serve registration opens.
// Written by the unauthenticated dashboard /api/waitlist route; email is unique
// so repeat signups collapse to a single row (the route treats P2002 as success).
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
