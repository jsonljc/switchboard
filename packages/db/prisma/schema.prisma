model ToolEvent {
  id            String   @id @default(uuid())
  sessionId     String
  runId         String
  stepIndex     Int
  toolName      String
  parameters    Json
  result        Json?
  isMutation    Boolean  @default(false)
  dollarsAtRisk Float    @default(0)
  durationMs    Int?
  envelopeId    String?
  timestamp     DateTime @default(now())

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

