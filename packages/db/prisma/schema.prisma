  avatarTierAtGeneration  Int
  avatarReferenceAssetIds String[]
  voiceAssetId            String?
  consentRecordId         String?

  policyVersion             String
  providerCapabilityVersion String
  selectedProvider          String
  providerModelSnapshot     String
