{
  "name": "User opts out and activity is logged",
  "parameters": {
    "BUSINESS_NAME": "TestBiz",
    "PIPELINE_STAGE": "nurturing",
    "OPPORTUNITY_ID": "opp-test-1",
    "LEAD_PROFILE": { "name": "Test Lead", "phone": "+1234567890" },
    "PERSONA_CONFIG": {
      "tone": "friendly and professional",
      "qualificationCriteria": { "budget": "has budget", "timeline": "within 3 months" },
      "disqualificationCriteria": { "location": "outside service area" },
      "escalationRules": { "pricing_question": true, "complex_requirement": true },
      "bookingLink": "https://calendly.com/testbiz",
      "customInstructions": ""
    }
  },
  "messages": [{ "role": "user", "content": "stop" }],
  "mockResponses": [
    {
      "content": [
        { "type": "text", "text": "Understood. I'll stop reaching out." },
        {
          "type": "tool_use",
          "id": "call-opt-1",
          "name": "crm-write.activity.log",
          "input": {
            "opportunityId": "opp-test-1",
            "type": "opt-out",
            "note": "Customer requested to stop outreach"
          }
        }
      ],
      "stop_reason": "tool_use"
    },
    {
      "content": [
        {
          "type": "text",
          "text": "I've noted your preference. We won't contact you again. If you ever change your mind, feel free to reach out. Take care!"
        }
      ],
      "stop_reason": "end_turn"
    }
  ],
  "assertions": [
    { "type": "tool_called", "toolName": "crm-write.activity.log" },
    { "type": "response_contains", "substring": "won't contact" }
  ]
}
