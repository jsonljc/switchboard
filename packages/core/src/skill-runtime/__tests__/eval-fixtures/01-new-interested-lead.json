  "messages": [{ "role": "user", "content": "Hi, I'm interested in your services" }],
  "mockResponses": [
    {
      "content": [
        {
          "type": "text",
          "text": "Thanks for reaching out to TestBiz! We'd love to learn more about what you're looking for. What specific services are you most interested in?"
