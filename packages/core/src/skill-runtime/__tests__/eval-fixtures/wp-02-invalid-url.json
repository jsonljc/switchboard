    {
      "content": [
        {
          "type": "text",
          "text": "{\"error\":\"Invalid URL format\"}"
        }
      ],
      "stop_reason": "end_turn"
    }
  ],
  "assertions": [
    { "type": "tool_called", "toolName": "web-scanner.validate-url" },
    { "type": "tool_not_called", "toolName": "web-scanner.fetch-pages" },
    { "type": "response_contains", "substring": "error" }
  ]
