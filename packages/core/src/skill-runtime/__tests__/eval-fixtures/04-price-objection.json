      ],
      "stop_reason": "end_turn"
    }
  ],
  "assertions": [
    { "type": "response_contains", "substring": "value" },
    { "type": "response_not_contains", "substring": "CompetitorCo" },
    { "type": "tool_not_called", "toolName": "crm-write.stage.update" },
    { "type": "tool_not_called", "toolName": "crm-query.contact.get" }
  ]
