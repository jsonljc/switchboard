    {
      "content": [
        {
          "type": "text",
          "text": "{\"profile_summary\":\"Shop Disguised appears to be an ecommerce store.\",\"business_model\":\"ecommerce\",\"price_positioning\":\"mid\",\"primary_cta\":\"buy\",\"lead_intent_type\":\"transactional\",\"platform\":\"shopify\",\"platform_confidence\":\"medium\",\"confidence\":\"high\",\"data_completeness\":\"high\",\"reasoning\":\"Tool detected wordpress but Shopify checkout URLs found in content\"}"
        }
      ],
      "stop_reason": "end_turn"
    }
