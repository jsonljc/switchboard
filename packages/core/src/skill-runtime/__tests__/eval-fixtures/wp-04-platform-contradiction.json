        }
      ],
      "stop_reason": "tool_use"
    },
    {
      "content": [
        {
          "type": "tool_use",
          "id": "call-3",
          "name": "web-scanner.detect-platform",
          "input": { "html": "<html>...</html>" }
        }
      ],
      "stop_reason": "tool_use"
    },
    {
      "content": [
        {
          "type": "tool_use",
          "id": "call-4",
          "name": "web-scanner.extract-business-info",
          "input": { "html": "<html>...</html>" }
        }
